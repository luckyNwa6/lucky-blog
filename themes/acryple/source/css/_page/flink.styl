#article-container
  .flink
    margin-bottom: 20px

    .flink-list
      overflow: auto
      padding: 10px 10px 0
      text-align: center

      & > .flink-list-item
        position: relative
        float: left
        overflow: hidden
        margin: 15px 7px
        width: calc(100% / 3 - 15px)
        height: 90px
        border-radius: 12px
        line-height: 17px
        box-shadow: 0 4px 12px rgba(51, 80, 143, 0.3)
        -webkit-transform: translateZ(0)

        +maxWidth1024()
          width: calc(50% - 15px) !important

        +maxWidth600()
          width: calc(100% - 15px) !important

        a
          color: #fff
          text-decoration: none
          .flink-item-icon
            float: left
            overflow: hidden
            margin: 15px 10px
            width: 60px
            height: 60px
            border-radius: 50%
            border: 2px solid rgba(255, 255, 255, 0.3)

            img
              width: 100%
              height: 100%
              object-fit: cover

          .img-alt
            display: none

    .flink-item-name
      @extend .limit-one-line
      padding: 16px 10px 0 0
      height: 40px
      font-weight: 600
      font-size: 1.43em
      color: #fff
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.1)

    .flink-item-desc
      @extend .limit-one-line
      padding: 16px 10px 16px 0
      height: 50px
      font-size: .93em
      color: rgba(255, 255, 255, 0.85)

    .flink-name
      margin-bottom: 5px
      font-weight: bold
      font-size: 1.5em